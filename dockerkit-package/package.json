{
  "name": "@phdsystems/dockerkit",
  "version": "1.0.0",
  "description": "Docker compliance and management toolkit for production environments",
  "main": "index.js",
  "bin": {
    "dck": "./bin/dck",
    "dockerkit": "./bin/dockerkit",
    "docker-comply": "./bin/docker-comply",
    "docker-template": "./bin/docker-template"
  },
  "scripts": {
