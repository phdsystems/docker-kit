# DockerKit Environment Configuration
# Copy this file to .env and customize as needed

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_BUILDKIT=1
DOCKER_CLI_EXPERIMENTAL=enabled

# DockerKit Settings
DOCKERKIT_VERSION=1.0.0
DOCKERKIT_LOG_LEVEL=info
DOCKERKIT_DATA_DIR=/var/lib/dockerkit/data
DOCKERKIT_LOG_DIR=/var/lib/dockerkit/logs
DOCKERKIT_CONFIG_DIR=/etc/dockerkit

# Container Settings
DOCKERKIT_MODE=interactive
DOCKERKIT_AUTO_UPDATE=false
DOCKERKIT_TELEMETRY=false

# API Configuration (optional)
API_ENABLED=false
API_PORT=8080
API_HOST=0.0.0.0
API_AUTH_ENABLED=false
API_AUTH_TOKEN=

# UI Configuration (optional)
UI_ENABLED=false
UI_PORT=3000
UI_HOST=0.0.0.0
UI_API_URL=http://dockerkit-api:8080

# Security Settings
DOCKERKIT_SECURITY_SCAN=true
DOCKERKIT_VULNERABILITY_CHECK=true
DOCKERKIT_AUDIT_LOG=true

# Resource Limits
DOCKERKIT_MEMORY_LIMIT=2g
DOCKERKIT_CPU_LIMIT=2
DOCKERKIT_DISK_QUOTA=10g

# Cleanup Settings
DOCKERKIT_AUTO_CLEANUP=false
DOCKERKIT_CLEANUP_INTERVAL=24h
DOCKERKIT_CLEANUP_KEEP_DAYS=7

# Export Settings
DOCKERKIT_EXPORT_FORMAT=json
DOCKERKIT_EXPORT_DIR=/var/lib/dockerkit/exports

# Monitoring Settings
DOCKERKIT_METRICS_ENABLED=false
DOCKERKIT_METRICS_INTERVAL=60s
DOCKERKIT_HEALTH_CHECK_INTERVAL=30s

# Network Settings
DOCKERKIT_NETWORK_NAME=dockerkit_network
DOCKERKIT_NETWORK_DRIVER=bridge
DOCKERKIT_NETWORK_SUBNET=172.28.0.0/16

# Volume Settings
DOCKERKIT_DATA_VOLUME=dockerkit_data
DOCKERKIT_LOGS_VOLUME=dockerkit_logs
DOCKERKIT_CONFIG_VOLUME=dockerkit_config

# Development Settings
DOCKERKIT_DEV_MODE=false
DOCKERKIT_DEBUG=false
DOCKERKIT_VERBOSE=false