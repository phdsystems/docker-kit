# Prometheus Monitoring Stack Environment Variables
# Copy to .env and update with your values

# Prometheus Configuration
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=10GB
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_EXTERNAL_LABELS_CLUSTER=production
PROMETHEUS_EXTERNAL_LABELS_REPLICA=A

# Alertmanager Configuration
ALERTMANAGER_ENABLED=true
ALERTMANAGER_PORT=9093
ALERTMANAGER_CLUSTER_PORT=9094
ALERTMANAGER_SMTP_FROM=alerts@example.com
ALERTMANAGER_SMTP_HOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_USERNAME=alerts@example.com
ALERTMANAGER_SMTP_PASSWORD=smtp-password
ALERTMANAGER_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ALERTMANAGER_PAGERDUTY_KEY=your-pagerduty-integration-key

# Grafana Configuration
GRAFANA_ENABLED=true
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-admin-password
GRAFANA_SECRET_KEY=change-this-secret-key
GRAFANA_DATABASE_TYPE=sqlite3
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_ANONYMOUS_ENABLED=false

# Node Exporter Configuration
NODE_EXPORTER_ENABLED=true
NODE_EXPORTER_PORT=9100

# cAdvisor Configuration
CADVISOR_ENABLED=true
CADVISOR_PORT=8080

# Pushgateway Configuration
PUSHGATEWAY_ENABLED=true
PUSHGATEWAY_PORT=9091

# Loki Configuration (optional)
LOKI_ENABLED=false
LOKI_PORT=3100
LOKI_RETENTION_PERIOD=168h

# Remote Write Configuration (optional)
REMOTE_WRITE_ENABLED=false
REMOTE_WRITE_URL=https://prometheus-remote.example.com/api/v1/write
REMOTE_WRITE_USERNAME=remote-user
REMOTE_WRITE_PASSWORD=remote-password

# Security
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USERNAME=prometheus
BASIC_AUTH_PASSWORD=prometheus-password

# TLS Configuration
TLS_ENABLED=false
TLS_CERT_FILE=/etc/prometheus/certs/cert.pem
TLS_KEY_FILE=/etc/prometheus/certs/key.pem