# Go Application Environment Variables
# Copy to .env and update with your values

# Application Settings
APP_ENV=production
APP_PORT=8080
APP_HOST=0.0.0.0
APP_NAME=myapp

# Go Runtime
GOGC=100
GOMEMLIMIT=1GiB
GOMAXPROCS=4

# Database Configuration
DB_DRIVER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=myapp
DB_USER=appuser
DB_PASSWORD=changeme
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme
REDIS_DB=0
REDIS_POOL_SIZE=10

# API Configuration
API_KEY=your-api-key-here
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=168h

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Metrics
METRICS_ENABLED=true
METRICS_PORT=2112
PPROF_ENABLED=false
PPROF_PORT=6060

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000,https://example.com
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Accept,Authorization,Content-Type,X-CSRF-Token

# TLS
TLS_ENABLED=false
TLS_CERT_FILE=/certs/cert.pem
TLS_KEY_FILE=/certs/key.pem

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=go-app
OTEL_TRACE_SAMPLER=always_on