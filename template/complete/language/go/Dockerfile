# Production-ready Go Dockerfile Template
# Generated by DCK - Docker Compliance Kit
# Compliance Score Target: 95%+

# Build stage
FROM golang:1.21-alpine3.19 AS builder

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Production Go application"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Install build dependencies and certificates
RUN apk add --no-cache \
    ca-certificates \
    git \
    make \
    gcc \
    musl-dev

# Set working directory
WORKDIR /build

# Copy go mod files
COPY go.mod go.sum ./

# Download dependencies
RUN go mod download && \
    go mod verify

# Copy source code
COPY . .

# Build the application with security flags
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -ldflags="-w -s -X main.version=${VERSION:-1.0.0} -extldflags '-static'" \
    -a -installsuffix cgo \
    -o app \
    ./cmd/main.go

# Security: Run gosec security scanner
RUN go install github.com/securego/gosec/v2/cmd/gosec@latest && \
    gosec -fmt json -out /tmp/gosec-report.json ./... || true

# Production stage - using distroless for minimal attack surface
FROM gcr.io/distroless/static:nonroot

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Production Go application"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Copy certificates
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/

# Copy binary from builder
COPY --from=builder --chown=nonroot:nonroot /build/app /app

# Use non-root user (distroless provides this)
USER nonroot:nonroot

# Expose port (change as needed)
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD ["/app", "health"] \
    || exit 1

# Run the application
ENTRYPOINT ["/app"]

