# Production-ready Python Dockerfile Template
# Generated by DCK - Docker Compliance Kit
# Compliance Score Target: 95%+

# Build stage
FROM python:3.12-slim-bookworm AS builder

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Production Python application"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Install build dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        gcc \
        python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Upgrade pip and install build tools
RUN pip install --no-cache-dir --upgrade \
    pip \
    setuptools \
    wheel

# Copy requirements
COPY requirements*.txt ./
COPY Pipfile* ./
COPY pyproject.toml* ./
COPY poetry.lock* ./

# Install Python dependencies
RUN if [ -f Pipfile ]; then \
        pip install pipenv && \
        pipenv install --deploy --system; \
    elif [ -f poetry.lock ]; then \
        pip install poetry && \
        poetry config virtualenvs.create false && \
        poetry install --no-dev --no-interaction --no-ansi; \
    elif [ -f requirements.txt ]; then \
        pip install --no-cache-dir -r requirements.txt; \
    fi

# Security: Run safety check on dependencies
RUN pip install safety && \
    safety check --json || true

# Production stage
FROM python:3.12-slim-bookworm

# Install runtime dependencies and security updates
RUN apt-get update && \
    apt-get upgrade -y && \
    apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        tini \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user
RUN groupadd -r python -g 1001 && \
    useradd -r -u 1001 -g python -m -d /home/python -s /bin/bash python

# Set working directory
WORKDIR /app

# Copy Python packages from builder
COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy application code
COPY --chown=python:python . .

# Security configurations
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONHASHSEED=random \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_DEFAULT_TIMEOUT=100

# Create directories with proper permissions
RUN mkdir -p /tmp/app /app/logs && \
    chown -R python:python /tmp/app /app/logs

# Switch to non-root user
USER python

# Expose port (change as needed)
EXPOSE 8000

# Health check (adjust endpoint as needed)
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" \
    || exit 1

# Use tini for proper signal handling
ENTRYPOINT ["tini", "--"]

# Run application (adjust as needed)
# For Django: ["python", "manage.py", "runserver", "0.0.0.0:8000"]
# For Flask: ["python", "-m", "flask", "run", "--host=0.0.0.0"]
# For FastAPI: ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
CMD ["python", "app.py"]