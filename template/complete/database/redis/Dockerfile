# Production-ready Redis Dockerfile Template
# Generated by DCK - Docker Compliance Kit
# Compliance Score Target: 95%+

FROM redis:7-alpine

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Production Redis cache/database"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Install security updates
RUN apk upgrade --no-cache && \
    apk add --no-cache \
        curl \
        ca-certificates \
    && rm -rf /var/cache/apk/*

# Create redis user if not exists (Alpine redis image has it)
# Redis user is already created in the official image

# Copy custom Redis configuration
COPY --chown=redis:redis redis.conf /usr/local/etc/redis/redis.conf

# Create necessary directories
RUN mkdir -p /data /var/log/redis && \
    chown redis:redis /data /var/log/redis

# Security: Disable dangerous commands in config
RUN echo "rename-command FLUSHDB \"\"" >> /usr/local/etc/redis/redis.conf && \
    echo "rename-command FLUSHALL \"\"" >> /usr/local/etc/redis/redis.conf && \
    echo "rename-command KEYS \"\"" >> /usr/local/etc/redis/redis.conf && \
    echo "rename-command CONFIG \"\"" >> /usr/local/etc/redis/redis.conf

# Volume for data persistence
VOLUME ["/data"]

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD redis-cli ping || exit 1

# Switch to redis user
USER redis

# Expose Redis port
EXPOSE 6379

# Start Redis with custom config
CMD ["redis-server", "/usr/local/etc/redis/redis.conf"]