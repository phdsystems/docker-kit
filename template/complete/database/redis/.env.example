# Redis Environment Variables
# Copy to .env and update with your values

# Redis Authentication
REDIS_PASSWORD=change-this-strong-password

# Redis Configuration
REDIS_PORT=6379
REDIS_DATABASES=16
REDIS_MAXMEMORY=1gb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_TIMEOUT=300
REDIS_TCP_KEEPALIVE=300
REDIS_TCP_BACKLOG=511

# Persistence
REDIS_SAVE_ENABLED=true
REDIS_SAVE_SCHEDULE="900 1 300 10 60 10000"
REDIS_AOF_ENABLED=yes
REDIS_AOF_FSYNC=everysec

# Cluster/Sentinel Configuration (optional)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_PORT=26379
REDIS_SENTINEL_QUORUM=2
REDIS_MASTER_NAME=mymaster

# RedisInsight (GUI)
REDISINSIGHT_ENABLED=true
REDISINSIGHT_PORT=8001

# Monitoring
REDIS_EXPORTER_ENABLED=true
REDIS_EXPORTER_PORT=9121