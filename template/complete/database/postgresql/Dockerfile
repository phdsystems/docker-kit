# Production-ready PostgreSQL Dockerfile Template
# Generated by DCK - Docker Compliance Kit
# Compliance Score Target: 95%+

FROM postgres:16-alpine

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Production PostgreSQL database"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Install additional packages and security updates
RUN apk upgrade --no-cache && \
    apk add --no-cache \
        curl \
        ca-certificates \
    && rm -rf /var/cache/apk/*

# Create custom user (postgres user already exists)
# PostgreSQL requires the postgres user for initialization

# Environment variables for configuration
ENV POSTGRES_DB=appdb
ENV POSTGRES_INITDB_ARGS="--encoding=UTF8 --locale=en_US.utf8"
ENV POSTGRES_HOST_AUTH_METHOD=scram-sha-256

# Security: Use secrets for passwords (set at runtime)
# ENV POSTGRES_PASSWORD should be set via docker secret or env file

# Custom PostgreSQL configuration
COPY --chown=postgres:postgres postgresql.conf /etc/postgresql/postgresql.conf
COPY --chown=postgres:postgres pg_hba.conf /etc/postgresql/pg_hba.conf

# Initialize scripts
COPY --chown=postgres:postgres ./init-scripts /docker-entrypoint-initdb.d/

# Create necessary directories with proper permissions
RUN mkdir -p /var/lib/postgresql/data /var/run/postgresql /var/log/postgresql && \
    chown -R postgres:postgres /var/lib/postgresql /var/run/postgresql /var/log/postgresql && \
    chmod 700 /var/lib/postgresql/data

# Volume for data persistence
VOLUME ["/var/lib/postgresql/data"]

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD pg_isready -U postgres || exit 1

# Switch to postgres user
USER postgres

# Expose PostgreSQL port
EXPOSE 5432

# Use the official entrypoint
ENTRYPOINT ["docker-entrypoint.sh"]

# Start PostgreSQL
CMD ["postgres", "-c", "config_file=/etc/postgresql/postgresql.conf"]