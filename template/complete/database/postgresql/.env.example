# PostgreSQL Database Environment Variables
# Copy to .env and update with your values

# Database Credentials
POSTGRES_DB=myapp
POSTGRES_USER=dbadmin
POSTGRES_PASSWORD=change-this-strong-password

# Additional Users (created via init scripts)
APP_DB_NAME=myapp
APP_DB_USER=appuser
APP_DB_PASSWORD=app-password-change-me
READONLY_USER=reader
READONLY_PASSWORD=readonly-password-change-me

# Database Configuration
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=en_US.utf8 --auth-host=scram-sha-256
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
PGDATA=/var/lib/postgresql/data/pgdata

# Performance Tuning
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_WAL_BUFFERS=16MB
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_RANDOM_PAGE_COST=1.1

# Replication Settings (optional)
POSTGRES_REPLICATION_MODE=master
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=replication-password
POSTGRES_REPLICATION_SLOT_NAME=replication_slot

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=my-db-backups
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1

# Monitoring
POSTGRES_EXPORTER_ENABLED=true
POSTGRES_EXPORTER_PORT=9187
POSTGRES_EXPORTER_USER=postgres_exporter
POSTGRES_EXPORTER_PASSWORD=exporter-password

# pgAdmin (optional)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=pgadmin-password
PGADMIN_PORT=5050

# Logging
POSTGRES_LOG_STATEMENT=all
POSTGRES_LOG_DURATION=on
POSTGRES_LOG_MIN_DURATION_STATEMENT=100