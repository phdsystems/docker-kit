# Keycloak IAM Environment Variables
# Copy to .env and update with your values

# Keycloak Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-this-admin-password

# Database Configuration
KC_DB=postgres
KC_DB_URL_HOST=postgres
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-this-db-password
KC_DB_SCHEMA=public

# Keycloak Configuration
KC_HOSTNAME=localhost
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_HTTPS_PORT=8443
KC_PROXY=edge
KC_LOG_LEVEL=INFO

# Features
KC_FEATURES=token-exchange,admin-fine-grained-authz
KC_METRICS_ENABLED=true
KC_HEALTH_ENABLED=true

# Cache
KC_CACHE=ispn
KC_CACHE_STACK=tcp

# Theme
KC_THEME_DEFAULT=keycloak
KC_THEME_WELCOME=keycloak
KC_THEME_ADMIN=keycloak

# PostgreSQL for Keycloak
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-this-db-password

# SMTP Configuration (optional)
KC_MAIL_HOST=smtp.gmail.com
KC_MAIL_PORT=587
KC_MAIL_FROM=noreply@example.com
KC_MAIL_USERNAME=your-email@gmail.com
KC_MAIL_PASSWORD=your-app-password
KC_MAIL_SSL=false
KC_MAIL_STARTTLS=true