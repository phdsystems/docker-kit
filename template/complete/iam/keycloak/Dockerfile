# Production-ready Keycloak Dockerfile Template
# Generated by DCK - Docker Compliance Kit
# Compliance Score Target: 95%+

FROM quay.io/keycloak/keycloak:23.0

# Metadata
LABEL maintainer="your-email@example.com"
LABEL version="1.0.0"
LABEL description="Keycloak Identity and Access Management"
LABEL org.opencontainers.image.source="https://github.com/yourusername/yourrepo"

# Switch to root for setup
USER root

# Install additional tools
RUN microdnf update -y && \
    microdnf install -y \
        curl \
        ca-certificates \
        jq \
    && microdnf clean all

# Create directories for custom providers and themes
RUN mkdir -p /opt/keycloak/providers /opt/keycloak/themes/custom && \
    chown -R keycloak:keycloak /opt/keycloak

# Copy custom providers (if any)
COPY --chown=keycloak:keycloak providers/ /opt/keycloak/providers/

# Copy custom themes (if any)
COPY --chown=keycloak:keycloak themes/ /opt/keycloak/themes/

# Copy realm configuration for import
COPY --chown=keycloak:keycloak realm-config.json /opt/keycloak/data/import/

# Environment variables
ENV KC_HEALTH_ENABLED=true
ENV KC_METRICS_ENABLED=true
ENV KC_HTTP_ENABLED=true
ENV KC_DB=postgres
ENV KC_DB_URL_HOST=postgres
ENV KC_DB_URL_DATABASE=keycloak
ENV KC_DB_USERNAME=keycloak
ENV KC_HOSTNAME_STRICT=false
ENV KC_HOSTNAME_STRICT_HTTPS=false
ENV KC_LOG_LEVEL=INFO
ENV KEYCLOAK_ADMIN=admin

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/health/ready || exit 1

# Switch back to keycloak user
USER keycloak

# Expose ports
# HTTP
EXPOSE 8080
# HTTPS
EXPOSE 8443
# Management
EXPOSE 9000

# Start Keycloak in production mode
ENTRYPOINT ["/opt/keycloak/bin/kc.sh"]
CMD ["start", "--optimized"]