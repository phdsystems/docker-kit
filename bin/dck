#!/bin/bash

# ==============================================================================
# DockerKit - Comprehensive Docker Management Toolkit
# ==============================================================================
# Main CLI interface for DockerKit providing unified access to Docker
# object inspection, management, and analysis tools
#
# IMPORTANT: This tool provides FULL Docker management capabilities.
# Users can search, manage, and delete ANY Docker resource.
# The safety restrictions (dck* prefix) only apply to DockerKit's
# own build/test/install scripts, NOT to this management tool.
# ==============================================================================

set -euo pipefail

# Script configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SCRIPTS_DIR="${SCRIPT_DIR}/main/src"
LIB_DIR="${SCRIPT_DIR}/main/src/lib"
DOCS_DIR="${SCRIPT_DIR}/docs"

# Source the Docker wrapper for sudo handling
source "${LIB_DIR}/docker-wrapper.sh"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m' # No Color

# Version
DOCKERKIT_VERSION="1.0.0"

# ==============================================================================
# Help and Usage
# ==============================================================================

show_help() {
    echo -e "$(cat <<EOF
${BOLD}${CYAN}DockerKit v${DOCKERKIT_VERSION}${NC}
${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}
${BOLD}Comprehensive Docker Management Toolkit${NC}

${BOLD}USAGE:${NC}
    dck <command> [options]

${BOLD}COMMANDS:${NC}
    ${CYAN}Object Inspection:${NC}
    images      Inspect and analyze Docker images
    containers  Inspect and analyze Docker containers  
    volumes     Inspect and analyze Docker volumes
    networks    Inspect and analyze Docker networks
    
    ${CYAN}Search & Discovery:${NC}
    search      Search Docker objects (images, containers, volumes, networks)
    
    ${CYAN}System Analysis:${NC}
    system      System-wide Docker analysis
    security    Security audit and analysis
    compliance  Docker best practices compliance checking
    template    Generate complete Docker stack templates
    cleanup     Clean up unused Docker objects
    stats       Real-time resource statistics
    
    ${CYAN}Advanced Tools:${NC}
    analyze     Advanced analysis for all Docker objects with metrics
    monitor     Real-time resource monitoring dashboard
    health      Container health check aggregator
    
    ${CYAN}Utilities:${NC}
    export      Export Docker objects to various formats
    backup      Backup Docker volumes and configurations
    migrate     Migrate containers between hosts
    
    ${CYAN}Documentation:${NC}
    docs        View Docker landscape documentation
    help        Show this help message
    version     Show version information

${BOLD}QUICK EXAMPLES:${NC}
    # Inspect all Docker images with details
    dck images
    
    # Advanced container analysis with sizes
    dck analyze containers
    
    # Show running containers with stats
    dck containers --running --stats
    
    # Analyze Docker security
    dck security
    
    # Check Docker compliance
    dck compliance dockerfile
    dck compliance container nginx
    
    # Clean up with dry-run
    dck cleanup --dry-run
    
    # Monitor resources live
    dck monitor
    
    # Export container data as JSON
    dck export containers --format json
    
    # View Docker landscape documentation
    dck docs
    
    # Search for Docker objects
    dck search images nginx
    dck search containers --status running
    dck search volumes --dangling
    dck search networks --unused

${BOLD}OPTIONS:${NC}
    -h, --help      Show help for specific command
    -v, --verbose   Enable verbose output
    -q, --quiet     Suppress non-essential output
    --no-color      Disable colored output

${DIM}For detailed help on any command, use: dck <command> --help${NC}
${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}
EOF
)"
}

show_version() {
    echo -e "${BOLD}${CYAN}DockerKit${NC} version ${DOCKERKIT_VERSION}"
    if [[ "$DOCKER_AVAILABLE" == "true" ]]; then
        echo -e "Docker version: $(docker_run --version 2>/dev/null | cut -d' ' -f3 | tr -d ',')"
    else
        echo -e "Docker version: Not available"
    fi
    echo -e "System: $(uname -s) $(uname -m)"
}

# ==============================================================================
# Command Handlers
# ==============================================================================

handle_images() {
    shift
    "$SCRIPTS_DIR/docker-images.sh" "$@"
}

handle_containers() {
    shift
    "$SCRIPTS_DIR/docker-containers.sh" "$@"
}

handle_volumes() {
    shift
    "$SCRIPTS_DIR/docker-volumes.sh" "$@"
}

handle_networks() {
    shift
    "$SCRIPTS_DIR/docker-networks.sh" "$@"
}

handle_system() {
    echo -e "${BOLD}${CYAN}Docker System Analysis${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    
    # Docker version
    echo -e "${BOLD}Docker Version:${NC}"
    docker version
    
    echo -e "\n${BOLD}System Information:${NC}"
    docker system info --format '
Containers:     {{.Containers}} ({{.ContainersRunning}} running, {{.ContainersPaused}} paused, {{.ContainersStopped}} stopped)
Images:         {{.Images}}
Server Version: {{.ServerVersion}}
Storage Driver: {{.Driver}}
Logging Driver: {{.LoggingDriver}}
Kernel Version: {{.KernelVersion}}
OS:             {{.OperatingSystem}}
Architecture:   {{.Architecture}}
CPUs:           {{.NCPU}}
Memory:         {{.MemTotal}}
Docker Root:    {{.DockerRootDir}}'
    
    echo -e "\n${BOLD}Disk Usage:${NC}"
    docker system df
    
    echo -e "\n${BOLD}Resource Usage by Type:${NC}"
    docker system df -v
}

handle_security() {
    "$SCRIPTS_DIR/docker-security.sh" "$@"
}

handle_compliance() {
    shift
    "$SCRIPTS_DIR/docker-compliance.sh" "$@"
}

handle_templates() {
    shift
    "$SCRIPTS_DIR/docker-template-generator.sh" "$@"
}

handle_cleanup() {
    # Use the advanced cleanup script if available
    if [[ -f "$SCRIPTS_DIR/docker-cleanup.sh" ]]; then
        "$SCRIPTS_DIR/docker-cleanup.sh" "$@"
    else
        # Fallback to basic cleanup
        echo -e "${BOLD}${CYAN}Docker Cleanup Utility${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
        
        echo -e "${YELLOW}WARNING: This will remove stopped containers, dangling images, and unused volumes!${NC}"
        read -p "Are you sure? (yes/no): " confirm
        if [[ "$confirm" == "yes" ]]; then
            echo -e "${CYAN}Running system prune...${NC}"
            docker system prune -a --volumes -f
            echo -e "\n${GREEN}Cleanup complete!${NC}"
        fi
    fi
}

handle_stats() {
    echo -e "${BOLD}${CYAN}Docker Real-time Statistics${NC}"
    echo -e "${DIM}Press Ctrl+C to exit${NC}\n"
    docker stats
}

handle_export() {
    shift
    local object_type="${1:-}"
    shift
    
    case "$object_type" in
        images)
            "$SCRIPTS_DIR/docker-images.sh" --format json "$@"
            ;;
        containers)
            "$SCRIPTS_DIR/docker-containers.sh" --format json "$@"
            ;;
        volumes)
            "$SCRIPTS_DIR/docker-volumes.sh" --format json "$@"
            ;;
        networks)
            "$SCRIPTS_DIR/docker-networks.sh" --format json "$@"
            ;;
        *)
            echo -e "${RED}Error: Unknown export type '$object_type'${NC}"
            echo "Valid types: images, containers, volumes, networks"
            exit 1
            ;;
    esac
}

handle_search() {
    shift
    local object_type="${1:-}"
    
    if [[ -z "$object_type" ]]; then
        echo -e "${BOLD}${CYAN}DockerKit Search${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
        echo -e "${BOLD}Usage:${NC} dck search <type> [options] [search_term]"
        echo ""
        echo -e "${BOLD}Types:${NC}"
        echo "  images      Search Docker images"
        echo "  containers  Search Docker containers"
        echo "  volumes     Search Docker volumes"
        echo "  networks    Search Docker networks"
        echo ""
        echo -e "${BOLD}Examples:${NC}"
        echo "  dck search images nginx"
        echo "  dck search containers -s running"
        echo "  dck search volumes --dangling"
        echo "  dck search networks -c mycontainer"
        exit 0
    fi
    
    shift
    case "$object_type" in
        images|image)
            "$SCRIPTS_DIR/docker-search-images.sh" "$@"
            ;;
        containers|container)
            "$SCRIPTS_DIR/docker-search-containers.sh" "$@"
            ;;
        volumes|volume)
            "$SCRIPTS_DIR/docker-search-volumes.sh" "$@"
            ;;
        networks|network)
            "$SCRIPTS_DIR/docker-search-networks.sh" "$@"
            ;;
        *)
            echo -e "${RED}Error: Unknown search type '$object_type'${NC}"
            echo "Valid types: images, containers, volumes, networks"
            exit 1
            ;;
    esac
}

handle_docs() {
    local doc="${1:-landscape}"
    
    case "$doc" in
        landscape|"")
            if command -v less &>/dev/null; then
                less "$DOCS_DIR/docker-landscape.md"
            else
                cat "$DOCS_DIR/docker-landscape.md"
            fi
            ;;
        *)
            if [[ -f "$DOCS_DIR/$doc.md" ]]; then
                if command -v less &>/dev/null; then
                    less "$DOCS_DIR/$doc.md"
                else
                    cat "$DOCS_DIR/$doc.md"
                fi
            else
                echo -e "${RED}Error: Documentation '$doc' not found${NC}"
                echo "Available docs:"
                ls -1 "$DOCS_DIR"/*.md 2>/dev/null | xargs -n1 basename | sed 's/\.md$//'
                exit 1
            fi
            ;;
    esac
}

# ==============================================================================
# Pre-flight Checks
# ==============================================================================

check_docker() {
    if ! command -v docker &>/dev/null; then
        echo -e "${RED}Error: Docker is not installed or not in PATH${NC}"
        echo -e "Please install Docker from https://docs.docker.com/get-docker/"
        exit 1
    fi
    
    # Docker wrapper already detected availability
    if [[ "$DOCKER_AVAILABLE" != "true" ]]; then
        echo -e "${RED}Error: Docker daemon is not accessible${NC}"
        echo -e "Please ensure Docker daemon is running"
        echo -e "Try: ${CYAN}sudo systemctl start docker${NC}"
        exit 1
    fi
    
    # Show if we're using sudo
    if [[ "$DOCKER_CMD" == *"sudo"* ]]; then
        echo -e "${DIM}Using sudo for Docker commands${NC}" >&2
    fi
}

check_permissions() {
    # Permissions are now handled by the docker-wrapper
    # This function is kept for backward compatibility but does nothing
    return 0
}

# ==============================================================================
# Main
# ==============================================================================

main() {
    # Handle no arguments
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    # Parse global options
    local verbose=false
    local quiet=false
    local no_color=false
    
    while [[ $# -gt 0 ]] && [[ "$1" == -* ]]; do
        case $1 in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            -q|--quiet)
                quiet=true
                shift
                ;;
            --no-color)
                no_color=true
                # Disable colors
                RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; MAGENTA=''
                BOLD=''; DIM=''; NC=''
                export SHOW_COLOR=false
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Get command
    local command="${1:-}"
    
    # Handle commands that don't need Docker
    case "$command" in
        help)
            show_help
            exit 0
            ;;
        version)
            show_version
            exit 0
            ;;
        docs)
            shift
            handle_docs "$@"
            exit 0
            ;;
    esac
    
    # Check Docker for commands that need it
    check_docker
    check_permissions
    
    # Handle Docker-dependent commands
    case "$command" in
        images)
            handle_images "$@"
            ;;
        containers)
            handle_containers "$@"
            ;;
        volumes)
            handle_volumes "$@"
            ;;
        networks)
            handle_networks "$@"
            ;;
        system)
            handle_system "$@"
            ;;
        security)
            handle_security "$@"
            ;;
        compliance)
            handle_compliance "$@"
            ;;
        template|templates)
            handle_templates "$@"
            ;;
        cleanup)
            shift
            handle_cleanup "$@"
            ;;
        stats)
            handle_stats "$@"
            ;;
        search)
            handle_search "$@"
            ;;
        export)
            handle_export "$@"
            ;;
        analyze)
            shift
            # Check if specific type is requested
            case "${1:-images}" in
                images)
                    shift
                    "$SCRIPTS_DIR/docker-advanced-images.sh" "$@"
                    ;;
                containers)
                    shift  
                    "$SCRIPTS_DIR/docker-advanced-containers.sh" "$@"
                    ;;
                volumes)
                    shift
                    "$SCRIPTS_DIR/docker-advanced-volumes.sh" "$@"
                    ;;
                networks)
                    shift
                    "$SCRIPTS_DIR/docker-advanced-networks.sh" "$@"
                    ;;
                *)
                    "$SCRIPTS_DIR/docker-advanced-images.sh" "$@"
                    ;;
            esac
            ;;
        monitor)
            shift
            "$SCRIPTS_DIR/docker-monitor.sh" "$@"
            ;;
        health)
            "$SCRIPTS_DIR/docker-monitor.sh" health "$@"
            ;;
        *)
            echo -e "${RED}Error: Unknown command '$command'${NC}"
            echo -e "Run '${CYAN}dck help${NC}' for usage information"
            exit 1
            ;;
    esac
}

# Make scripts executable
for script in "$SCRIPTS_DIR"/*.sh; do
    [[ -f "$script" ]] && chmod +x "$script"
done

# Run main function
main "$@"